{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["react"]
  },
  "include": [
    "src/index.ts",
    "src/button/index.ts",
    "src/button/button.tsx",
    "src/button/button.types.ts",
    "src/button/button.variants.web.ts",
    "src/button/button.variants.shared.ts",
    "src/card/index.ts",
    "src/card/card.tsx",
    "src/card/card.types.ts",
    "src/card/card.variants.web.ts",
    "src/card/card.variants.shared.ts",
    "src/flow/index.ts",
    "src/flow/flow.children.ts",
    "src/flow/flow.tsx",
    "src/flow/flow.types.ts",
    "src/flow/flow.variants.web.ts",
    "src/flow/flow.variants.shared.ts",
    "src/text/index.ts",
    "src/text/text.tsx",
    "src/text/text.types.ts",
    "src/text/text.variants.shared.ts",
    "src/utils/cn.ts"
  ]
}
