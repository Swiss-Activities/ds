{
  "name": "@swiss-activities/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./src/index.native.ts",
        "default": "./src/index.native.ts"
      },
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./web": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./native": {
      "types": "./src/index.native.ts",
      "default": "./src/index.native.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./tokens/colors": {
      "types": "./src/tokens/colors.ts",
      "default": "./src/tokens/colors.ts"
    },
    "./tokens/radius": {
      "types": "./src/tokens/radius.ts",
      "default": "./src/tokens/radius.ts"
    },
    "./tokens/screens": {
      "types": "./src/tokens/screens.ts",
      "default": "./src/tokens/screens.ts"
    },
    "./icons": {
      "react-native": {
        "types": "./src/icons/index.native.ts",
        "default": "./src/icons/index.native.ts"
      },
      "types": "./src/icons/index.ts",
      "default": "./src/icons/index.ts"
    },
    "./breadcrumbs/breadcrumbs.types": {
      "types": "./src/breadcrumbs/breadcrumbs.types.ts",
      "default": "./src/breadcrumbs/breadcrumbs.types.ts"
    },
    "./badge/badge.types": {
      "types": "./src/badge/badge.types.ts",
      "default": "./src/badge/badge.types.ts"
    },
    "./card/card.types": {
      "types": "./src/card/card.types.ts",
      "default": "./src/card/card.types.ts"
    },
    "./skeleton/skeleton.types": {
      "types": "./src/skeleton/skeleton.types.ts",
      "default": "./src/skeleton/skeleton.types.ts"
    },
    "./tokens/animations": {
      "types": "./src/tokens/animations.ts",
      "default": "./src/tokens/animations.ts"
    },
    "./text/text.types": {
      "types": "./src/text/text.types.ts",
      "default": "./src/text/text.types.ts"
    },
    "./image-card/image-card.types": {
      "types": "./src/image-card/image-card.types.ts",
      "default": "./src/image-card/image-card.types.ts"
    },
    "./rating/rating.types": {
      "types": "./src/rating/rating.types.ts",
      "default": "./src/rating/rating.types.ts"
    },
    "./header/header.types": {
      "types": "./src/header/header.types.ts",
      "default": "./src/header/header.types.ts"
    },
    "./horizontal-scroller/horizontal-scroller.types": {
      "types": "./src/horizontal-scroller/horizontal-scroller.types.ts",
      "default": "./src/horizontal-scroller/horizontal-scroller.types.ts"
    },
    "./logo/markup": {
      "types": "./src/logo/logo.markup.ts",
      "default": "./src/logo/logo.markup.ts"
    },
    "./styles/sa-theme.css": "./src/styles/sa-theme.css"
  },
  "scripts": {
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck:native": "tsc -p tsconfig.native.json --noEmit",
    "typecheck": "bun run typecheck:web && bun run typecheck:native"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.82.0",
    "react-native-svg": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "15.12.1",
    "react-native-css": "^3.0.6",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "lucide-react-native": "^0.542.0",
    "tailwind-merge": "^3.5.0"
  }
}
