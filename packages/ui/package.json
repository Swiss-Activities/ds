{
  "name": "@swiss-activities/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./src/index.native.ts",
        "default": "./src/index.native.ts"
      },
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./web": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./native": {
      "types": "./src/index.native.ts",
      "default": "./src/index.native.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./styles/sa-variables.css": "./src/styles/sa-variables.css",
    "./styles/sa-theme.css": "./src/styles/sa-theme.css"
  },
  "scripts": {
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck:native": "tsc -p tsconfig.native.json --noEmit",
    "typecheck": "bun run typecheck:web && bun run typecheck:native"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": ">=0.82.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react-native-css": "^3.0.4",
    "typescript": "~5.9.3"
  }
}
