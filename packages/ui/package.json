{
  "name": "@swiss-activities/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "web": ["dist/index.d.ts"],
      "tokens": ["dist/tokens/index.d.ts"],
      "tokens/*": ["dist/tokens/*.d.ts"],
      "icons": ["dist/icons/index.d.ts"],
      "logo/markup": ["dist/logo/logo.markup.d.ts"],
      "breadcrumbs/breadcrumbs.types": [
        "dist/breadcrumbs/breadcrumbs.types.d.ts"
      ],
      "badge/badge.types": ["dist/badge/badge.types.d.ts"],
      "card/card.types": ["dist/card/card.types.d.ts"],
      "skeleton/skeleton.types": ["dist/skeleton/skeleton.types.d.ts"],
      "text/text.types": ["dist/text/text.types.d.ts"],
      "image-card/image-card.types": [
        "dist/image-card/image-card.types.d.ts"
      ],
      "rating/rating.types": ["dist/rating/rating.types.d.ts"],
      "header/header.types": ["dist/header/header.types.d.ts"],
      "horizontal-scroller/horizontal-scroller.types": [
        "dist/horizontal-scroller/horizontal-scroller.types.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "react-native": {
        "types": "./src/index.native.ts",
        "default": "./src/index.native.ts"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./native": {
      "types": "./src/index.native.ts",
      "default": "./src/index.native.ts"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "default": "./dist/tokens/index.js"
    },
    "./tokens/colors": {
      "types": "./dist/tokens/colors.d.ts",
      "default": "./dist/tokens/colors.js"
    },
    "./tokens/radius": {
      "types": "./dist/tokens/radius.d.ts",
      "default": "./dist/tokens/radius.js"
    },
    "./tokens/screens": {
      "types": "./dist/tokens/screens.d.ts",
      "default": "./dist/tokens/screens.js"
    },
    "./icons": {
      "react-native": {
        "types": "./src/icons/index.native.ts",
        "default": "./src/icons/index.native.ts"
      },
      "types": "./dist/icons/index.d.ts",
      "default": "./dist/icons/index.js"
    },
    "./breadcrumbs/breadcrumbs.types": {
      "types": "./dist/breadcrumbs/breadcrumbs.types.d.ts",
      "default": "./dist/breadcrumbs/breadcrumbs.types.js"
    },
    "./badge/badge.types": {
      "types": "./dist/badge/badge.types.d.ts",
      "default": "./dist/badge/badge.types.js"
    },
    "./card/card.types": {
      "types": "./dist/card/card.types.d.ts",
      "default": "./dist/card/card.types.js"
    },
    "./skeleton/skeleton.types": {
      "types": "./dist/skeleton/skeleton.types.d.ts",
      "default": "./dist/skeleton/skeleton.types.js"
    },
    "./tokens/animations": {
      "types": "./dist/tokens/animations.d.ts",
      "default": "./dist/tokens/animations.js"
    },
    "./text/text.types": {
      "types": "./dist/text/text.types.d.ts",
      "default": "./dist/text/text.types.js"
    },
    "./image-card/image-card.types": {
      "types": "./dist/image-card/image-card.types.d.ts",
      "default": "./dist/image-card/image-card.types.js"
    },
    "./rating/rating.types": {
      "types": "./dist/rating/rating.types.d.ts",
      "default": "./dist/rating/rating.types.js"
    },
    "./header/header.types": {
      "types": "./dist/header/header.types.d.ts",
      "default": "./dist/header/header.types.js"
    },
    "./horizontal-scroller/horizontal-scroller.types": {
      "types": "./dist/horizontal-scroller/horizontal-scroller.types.d.ts",
      "default": "./dist/horizontal-scroller/horizontal-scroller.types.js"
    },
    "./logo/markup": {
      "types": "./dist/logo/logo.markup.d.ts",
      "default": "./dist/logo/logo.markup.js"
    },
    "./styles/sa-theme.css": "./dist/styles/sa-theme.css"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/styles && cp src/styles/sa-theme.css dist/styles/sa-theme.css",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck:native": "tsc -p tsconfig.native.json --noEmit",
    "typecheck": "bun run typecheck:web && bun run typecheck:native"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.82.0",
    "react-native-svg": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "15.12.1",
    "react-native-css": "^3.0.6",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "@silk-hq/components": "^0.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "lucide-react-native": "^0.542.0",
    "tailwind-merge": "^3.5.0"
  }
}
