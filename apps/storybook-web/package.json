{
  "name": "@swiss-activities/storybook-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "storybook build -o dist",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "rm -rf node_modules/.cache && storybook dev -p 6006",
    "build-storybook": "storybook build -o dist"
  },
  "dependencies": {
    "@swiss-activities/dummy-data": "workspace:*",
    "@swiss-activities/data": "workspace:*",
    "@swiss-activities/ui": "workspace:*",
    "@tanstack/react-query": "^5.59.15",
    "lucide-react": "^0.542.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
