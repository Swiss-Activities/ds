{
  "expo": {
    "name": "Swiss Activities Design System",
    "slug": "design-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swissactivities.designsystem",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.swissactivities.designsystem",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/inter-v11-latin-regular.ttf",
            "./assets/fonts/inter-v11-latin-500.ttf",
            "./assets/fonts/inter-v11-latin-600.ttf",
            "./assets/fonts/inter-v11-latin-700.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Inter",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/inter-v11-latin-regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/inter-v11-latin-500.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/inter-v11-latin-600.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/inter-v11-latin-700.ttf",
                    "weight": 700
                  }
                ]
              }
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1fd275b3-c8a4-4478-b60a-f5c5924b2198"
      }
    },
    "owner": "swiss_activities"
  }
}
